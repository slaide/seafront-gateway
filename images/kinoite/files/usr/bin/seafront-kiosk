#!/usr/bin/env bash
# Break-glass operator console: open the LOCAL seafront web UI fullscreen.
# Runs on the box's own desktop — no gateway, no backbone, no SSH involved.
# Waits for the local server to answer, then launches the browser in kiosk mode.
set -u
URL="http://localhost:8000"
for _ in $(seq 1 60); do
    if curl -fsS -o /dev/null "$URL" 2>/dev/null; then break; fi
    sleep 2
done
exec firefox --kiosk "$URL"
