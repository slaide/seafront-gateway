# seafront APP image — the microscope-control server, one OCI image for the whole fleet.
# Built on the gateway (which has on-demand internet), pushed to the gateway registry,
# pulled by every box. No pip/uv/wheel resolution ever happens on a box.
#
#   podman build -t 192.168.50.1:5000/seafront:stable \
#     --build-arg SEAFRONT_REF=<sha|tag> images/seafront
#
# The custom VCS deps (gxipy/toupcam/seaconfig) are fetched by `uv sync` at build time,
# which is why this must build where there's internet.
FROM python:3.13-slim-bookworm

# runtime libs: opencv needs libGL+glib; cameras/Teensy need libusb; git for the VCS deps;
# usbutils gives `lsusb`, which seafront's Galaxy enumeration + list_squid_hardware.py shell
# out to for the raw USB VID:PID lookup (without it, camera discovery finds nothing).
RUN apt-get update && apt-get install -y --no-install-recommends \
        git libgl1 libglib2.0-0 libusb-1.0-0 usbutils \
    && rm -rf /var/lib/apt/lists/*

# uv, pinned by digest-free tag (build host has internet)
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv

ARG SEAFRONT_REPO=https://github.com/slaide/seafront.git
# Pinned for reproducibility. scripts/build-images.sh is the source of truth and passes
# the pinned SHA via --build-arg; keep this default in sync with it when bumping.
ARG SEAFRONT_REF=dba35b3773dea851939f8964a30b9aa37ec3cd9d
RUN git clone "$SEAFRONT_REPO" /app \
    && git -C /app checkout "$SEAFRONT_REF"
WORKDIR /app
# --frozen: build exactly what seafront's committed uv.lock pins (reproducible fleet
# image). --no-dev keeps pyright/ruff/node out of the runtime image. The cache mount +
# lowered concurrency make the (network-heavy) build robust on the gateway's link.
RUN --mount=type=cache,target=/root/.cache/uv \
    UV_CONCURRENT_DOWNLOADS=4 UV_HTTP_TIMEOUT=120 uv sync --frozen --no-dev

# Daheng Galaxy camera SDK (native). gxipy — installed above by uv — loads
# /usr/lib/libgxiapi.so via ctypes but does NOT ship the SDK, so without it camera discovery
# fails with "Cannot find libgxiapi.so". The wrapper fork ships the SDK as a self-extracting
# install.run (a base64-embedded tarball); the unpacked Galaxy_camera/ tree is GITIGNORED, so
# we extract the tarball from install.run rather than reading files that aren't in the repo.
# We take only the RUNTIME bits — libgxiapi.so + the GenTL transport producers (.cti) it
# dlopens to enumerate cameras (GxU3VTL = USB3 Vision, our MER2-*U3M; GxGVTL = GigE) — and
# point libgxiapi at them via GENICAM_GENTL64_PATH. We deliberately do NOT *run* install.run:
# it is interactive and does host-side setup (udev rules, usbfs via /sys) that belongs in the
# OS image, not a container build (the usbfs karg + udev perms are in the Kinoite image).
ARG GXIPY_REPO=https://github.com/slaide/daheng-imaging-gxipy.git
RUN git clone --depth 1 "$GXIPY_REPO" /tmp/gx \
    && cd /tmp/gx/install_sdk/linux-x86 \
    && A=$(awk '/^__ARCHIVE_FOLLOWS__/{print NR+1; exit}' install.run) \
    && tail -n +"$A" install.run | base64 --decode | tar xz \
    && SDK=Galaxy_camera/lib/x86_64 \
    && install -Dm755 "$SDK/libgxiapi.so" /usr/lib/libgxiapi.so \
    && install -Dm755 "$SDK/GxU3VTL.cti"  /usr/lib/GxU3VTL.cti \
    && install -Dm755 "$SDK/GxGVTL.cti"   /usr/lib/GxGVTL.cti \
    && ldconfig \
    && rm -rf /tmp/gx
ENV GENICAM_GENTL64_PATH=/usr/lib

# Config + acquired images live on a host volume mounted here (see the quadlet).
# So the container is stateless; config.json is pushed to the box, not baked.
# Must equal $HOME/seafront: the server honors SEAFRONT_HOME, but seafront's
# generate_default_protocol.py subprocess ignores it and reads $HOME/seafront/config.json.
# Root's $HOME is /root, so both agree on /root/seafront. (Fix that upstream and this
# can move to e.g. /var/seafront.)
ENV SEAFRONT_HOME=/root/seafront
# Which profile in config.json to run. Default = mock until real hardware is wired.
# A per-box override file on the mounted writable dir (/root/seafront/active_microscope,
# i.e. ~pharmbio/seafront/active_microscope on the host) takes precedence when present —
# so the gateway can switch profiles by writing that file + `systemctl restart seafront`,
# with no image rebuild, no /etc edit, and no sudo beyond the restart it already has.
ENV SEAFRONT_MICROSCOPE=mocroscope

EXPOSE 8000
# `uv run --no-sync` runs the pre-built venv as-is: idiomatic, and it never touches the
# network. (Plain `uv run` re-resolves and FAILS offline — verified; --no-sync is required.)
# Bind 0.0.0.0, NOT ::: uvicorn's IPv6 socket comes up V6ONLY (confirmed on the gateway
# dashboard), and podman PublishPort reaches this socket over IPv4 on the IPv4-only
# backbone — `::` would leave seafront reachable only on the box's own ::1 (kiosk) while
# the gateway/Caddy proxy to <box>:8000 gets connection-refused (502).
CMD ["sh", "-c", "M=\"$SEAFRONT_MICROSCOPE\"; [ -s /root/seafront/active_microscope ] && M=\"$(cat /root/seafront/active_microscope)\"; exec uv run --no-sync python -m seafront --microscope \"$M\" --host 0.0.0.0 --port 8000"]
